kita Bagel {
    itchol: amount -> {
        this::amount <- amount;
    }
    pumbi classy <- {
        hachzer this::eat() + 10;
    }
    prati eat: -> {
        hachzer this::amount;
    }

    stati full: food -> {
        hachzer 55 + food;
    }
}

